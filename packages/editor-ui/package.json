{
  "name": "@vitrea/editor-ui",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./glass": {
      "types": "./dist/lib/glass.d.ts",
      "import": "./dist/lib/glass.js"
    },
    "./modal": {
      "types": "./dist/components/modal.d.ts",
      "import": "./dist/components/modal.js"
    },
    "./confirm-dialog": {
      "types": "./dist/components/confirm-dialog.d.ts",
      "import": "./dist/components/confirm-dialog.js"
    },
    "./prompt-dialog": {
      "types": "./dist/components/prompt-dialog.d.ts",
      "import": "./dist/components/prompt-dialog.js"
    },
    "./spinner": {
      "types": "./dist/components/spinner.d.ts",
      "import": "./dist/components/spinner.js"
    },
    "./empty-state": {
      "types": "./dist/components/empty-state.d.ts",
      "import": "./dist/components/empty-state.js"
    },
    "./search-input": {
      "types": "./dist/components/search-input.d.ts",
      "import": "./dist/components/search-input.js"
    },
    "./file-upload": {
      "types": "./dist/components/file-upload.d.ts",
      "import": "./dist/components/file-upload.js"
    },
    "./page-shell": {
      "types": "./dist/components/page-shell.d.ts",
      "import": "./dist/components/page-shell.js"
    },
    "./dropdown": {
      "types": "./dist/components/dropdown.d.ts",
      "import": "./dist/components/dropdown.js"
    },
    "./scroll-area": {
      "types": "./dist/components/scroll-area.d.ts",
