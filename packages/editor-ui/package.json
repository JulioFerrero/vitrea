    },
    "./separator": {
      "types": "./dist/components/separator.d.ts",
      "import": "./dist/components/separator.js"
    },
    "./form-primitives": {
      "types": "./dist/components/form-primitives.d.ts",
      "import": "./dist/components/form-primitives.js"
    },
    "./icon-button": {
      "types": "./dist/components/icon-button.d.ts",
      "import": "./dist/components/icon-button.js"
    },
    "./avatar": {
      "types": "./dist/components/avatar.d.ts",
      "import": "./dist/components/avatar.js"
    },
    "./collapsible-section": {
      "types": "./dist/components/collapsible-section.d.ts",
      "import": "./dist/components/collapsible-section.js"
    },
    "./panel": {
      "types": "./dist/components/panel.d.ts",
      "import": "./dist/components/panel.js"
    },
    "./toolbar": {
      "types": "./dist/components/toolbar.d.ts",
      "import": "./dist/components/toolbar.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@vitrea/utils": "workspace:*",
    "lucide-react": "^0.509.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
