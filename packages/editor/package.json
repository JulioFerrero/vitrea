{
  "name": "@vitrea/editor",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/ws.d.ts"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@vitrea/auth": "workspace:*",
    "@vitrea/cms": "workspace:*",
    "@vitrea/database": "workspace:*",
    "@vitrea/editor-ui": "workspace:*",
    "@vitrea/render": "workspace:*",
    "@vitrea/ui": "workspace:*",
    "@vitrea/utils": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.43.0",
    "hono": "^4.12.21",
    "lucide-react": "^0.509.0",
    "nanoid": "^5.1.11",
    "react": "^19.1.0",
    "react-arborist": "^3.6.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
