{
  "workspace": ["apps/*", "packages/*"],
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "exclude": ["no-sloppy-imports", "no-import-prefix", "no-unversioned-import", "no-slow-types", "no-explicit-any"]
    }
  },
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "unsafe-proto",
    "sloppy-imports"
  ],
  "tasks": {
    "dev:web": "cd apps/web && deno task dev",
    "dev:editor": "cd apps/editor && deno task dev",
    "build:web": "cd apps/web && deno task build",
    "build:editor": "cd apps/editor && deno task build",
    "build": "deno task build:web && deno task build:editor",
    "check": "deno check packages/*/src/index.ts apps/web/main.ts apps/editor/src/main.tsx",
    "lint": "deno lint packages/ apps/",
    "fmt": "deno fmt packages/ apps/",
    "fmt:check": "deno fmt --check packages/ apps/",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:seed": "deno run -A --env=.env packages/database/src/seed.ts",
    "db:push": "deno run -A --env=.env npm:drizzle-kit push",
    "db:generate": "deno run -A --env=.env npm:drizzle-kit generate",
    "example:fresh": "deno task -c examples/fresh/deno.json dev",
    "example:vite": "cd examples/vite-react && deno run -A npm:vite"
  },
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
