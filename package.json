{
  "name": "web-builder",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "changeset": "changeset",
    "version:packages": "changeset version",
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "release": "pnpm build:packages && changeset publish",
    "release:versioned": "node ./scripts/publish-versioned-packages.mjs",
    "dev:create": "pnpm --filter @vitrea/create dev",
    "build:create": "pnpm --filter @vitrea/create build",
    "dev:web": "pnpm --filter @app/web dev",
    "dev:editor": "pnpm --filter @app/editor dev",
    "dev": "concurrently -n web,editor -c blue,magenta \"pnpm dev:web\" \"pnpm dev:editor\"",
    "lint:packages": "pnpm -r --filter \"./packages/*\" run lint",
    "build:web": "pnpm --filter @app/web build",
    "build:editor": "pnpm --filter @app/editor build",
    "build": "pnpm build:web && pnpm build:editor",
    "db:push": "drizzle-kit push --config=./packages/database/drizzle.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.29.0",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.34.0"
  }
}
